# データベース（Supabase Local）
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres

# BetterAuth
BETTER_AUTH_SECRET=dev-secret-change-me-in-production
BETTER_AUTH_URL=http://localhost:8787

# フロントエンドURL
FRONTEND_URL=http://localhost:3000

# APIポート
PORT=8787

# ログレベル
LOG_LEVEL=debug

# Supabase（Storage等で使用）
SUPABASE_URL=http://127.0.0.1:54331
SUPABASE_SERVICE_ROLE_KEY=

# OAuth（ローカル開発ではemail/passwordで認証するため空でOK）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=
